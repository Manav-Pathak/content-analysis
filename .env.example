# Postgres service started by Docker Compose
POSTGRES_DB=brandtrack
POSTGRES_USER=manav
POSTGRES_PASSWORD=change-me

# FastAPI container talks to Postgres through the Docker service name
DATABASE_URL=postgresql://manav:change-me@db:5432/brandtrack

# Optional: only set this when you intentionally run FastAPI outside Docker
# against the host-mapped Docker Postgres port.
LOCAL_DATABASE_URL=postgresql://manav:change-me@localhost:5433/brandtrack

# Optional pgAdmin profile
PGADMIN_DEFAULT_EMAIL=manav@example.com
PGADMIN_DEFAULT_PASSWORD=change-me

# JWT settings
JWT_SECRET_KEY=change-this-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
